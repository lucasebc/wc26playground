# ─── MongoDB ──────────────────────────────────────────────────────────────────
# Option A: use the local Docker MongoDB container (docker-compose)
MONGODB_URI=mongodb://admin:secret@mongo:27017/worldcup2026?authSource=admin

# Option B: use MongoDB Atlas (cloud)
# MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/worldcup2026

# ─── MongoDB container credentials (only needed for Docker Compose) ───────────
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=secret

